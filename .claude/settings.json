{
  "permissions": {
    "deny": [
      "Read(.env.local)",
      "Read(.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(*.ts|*.tsx)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && npx tsc --noEmit 2>&1 | head -30"
          }
        ]
      }
    ]
  }
}
